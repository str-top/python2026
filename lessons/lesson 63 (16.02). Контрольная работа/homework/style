body {
    font-family: Arial, Helvetica, sans-serif;
    background-color: #f5f7fb;
    color: #1f2937;
    margin: 0;
    padding: 24px;
}

h1 {
    color: #1d4ed8;
    margin: 0 0 12px 0;
}

ul {
    margin: 8px 0 12px 20px;
    padding: 0;
}

li {
   margin: 6px 0;
}

a {
    color: #0f765e;
    text-decoration: none;
}

a:hover {
   color: #115e59;
}

img {
    max-width: 100%;
    display: block;
    margin-top: 12px;
    border-radius: 10px;
    order: 1px solid #cbd5e1;
}